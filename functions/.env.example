APP_CHECK_ENFORCE=false
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
PUBSUB_EMULATOR_HOST=firebase-emulator:8085
FIRESTORE_JOBS_COLLECTION=skybridge-jobs
FIRESTORE_CREDENTIALS_COLLECTION=skybridge-credentials
FIRESTORE_EMULATOR_HOST=firebase-emulator:8080
# Optional override; defaults to the Firebase default bucket for the active project.
# GCS_BUCKET=my-project.firebasestorage.app
GCS_PREFIX=jobs
STORAGE_EMULATOR_HOST=http://firebase-emulator:9199
BACKEND_CREDENTIAL_TTL=900
BACKEND_WAIT_FOR_PROCESSING=true
BACKEND_PROCESSING_INTERVAL=20
BACKEND_PROCESSING_TIMEOUT=3600
DEV_USE_MOCKS=1
MOCK_CLOUD_AHOY_BASE_URL=http://mock-cloudahoy:8081/api
MOCK_FLYSTO_BASE_URL=http://mock-flysto:8082
