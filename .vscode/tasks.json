{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compose: Up (detached)",
      "type": "shell",
      "command": "docker compose up -d",
      "problemMatcher": []
    },
    {
      "label": "Compose: Down",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": []
    },
    {
      "label": "Compose: Build",
      "type": "shell",
      "command": "docker compose build",
      "problemMatcher": []
    },
    {
      "label": "Firebase: Deploy (Functions + Hosting)",
      "type": "shell",
      "command": "./scripts/firebase-deploy.sh --project ${input:firebaseProjectId}",
      "problemMatcher": []
    },
    {
      "label": "Workspace: Clean",
      "type": "shell",
      "command": "./scripts/clean-workspace.sh",
      "problemMatcher": []
    },
    {
      "label": "Git: Cleanup Merged Branches",
      "type": "shell",
      "command": "./scripts/cleanup-merged-branches.sh",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "firebaseProjectId",
      "type": "promptString",
      "description": "Firebase project id for deployment",
      "default": "skybridge-inspirespace"
    }
  ]
}
