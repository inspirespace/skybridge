{
  "name": "skybridge-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "devcontainer"
  },
  "workspaceFolder": "/workspaces/skybridge",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=skybridge-shell-history,target=/var/devcontainer/history,type=volume",
    "source=skybridge-codex,target=/var/devcontainer/codex,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode"
    },
    "ghcr.io/devcontainers-extra/features/starship:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.analysis.extraPaths": [
          "${workspaceFolder}"
        ],
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "python.testing.autoTestDiscoverOnSaveEnabled": true,
        "python.testing.cwd": "${workspaceFolder}",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        }
      },
      "extensions": [
        "openai.chatgpt",
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteUser": "vscode",
  "remoteEnv": {
    "HISTFILE": "/var/devcontainer/history/.zsh_history",
    "STARSHIP_CONFIG": "/workspaces/skybridge/.devcontainer/starship.toml",
    "VIRTUAL_ENV": "/opt/venv",
    "PATH": "/opt/venv/bin:/home/vscode/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
    "VIRTUAL_ENV_DISABLE_PROMPT": "1"
  },
  "postCreateCommand": "uv sync --frozen --extra dev && (grep -qxF 'eval \"$(starship init zsh)\"' ~/.zshrc || echo 'eval \"$(starship init zsh)\"' >> ~/.zshrc) && (sed -i '/source \\/opt\\/venv\\/bin\\/activate/d' ~/.zshrc || true)",
  "postStartCommand": "bash .devcontainer/setup-history.sh && bash .devcontainer/setup-codex.sh"
}
