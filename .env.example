CLOUD_AHOY_BASE_URL=https://www.cloudahoy.com/api
CLOUD_AHOY_WEB_BASE_URL=https://www.cloudahoy.com
DEV_USE_MOCKS=1
CLOUD_AHOY_EMAIL=
CLOUD_AHOY_PASSWORD=
CLOUD_AHOY_FLIGHTS_URL=
CLOUD_AHOY_EXPORT_URL_TEMPLATE=
CLOUD_AHOY_EXPORT_FORMAT=g3x
CLOUD_AHOY_EXPORT_FORMATS=g3x,gpx
FLYSTO_BASE_URL=https://www.flysto.net
FLYSTO_WEB_BASE_URL=https://www.flysto.net
FLYSTO_EMAIL=
FLYSTO_PASSWORD=
FLYSTO_UPLOAD_URL=
FLYSTO_SESSION_COOKIE=
FLYSTO_LOG_UPLOAD_URL=
FLYSTO_INCLUDE_METADATA=false
FLYSTO_API_VERSION=
MODE=auto
BROWSER_HEADLESS=true
DRY_RUN=false
MAX_FLIGHTS=

# Backend (Firebase / GCP)
AUTH_MODE=firebase
AUTH_EMULATOR_TRUST_TOKENS=false
BACKEND_RETENTION_DAYS=7
# 32-byte urlsafe base64 key, e.g. generated via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKEND_ENCRYPTION_KEY=
CORS_ALLOW_ORIGINS=https://skybridge.localhost,https://emulator.skybridge.localhost
BACKEND_USE_WORKER=true
BACKEND_PUBSUB_ENABLED=1
PUBSUB_TOPIC=skybridge-job-queue
BACKEND_FIRESTORE_ENABLED=1
FIRESTORE_JOBS_COLLECTION=skybridge-jobs
FIRESTORE_CREDENTIALS_COLLECTION=skybridge-credentials
BACKEND_GCS_ENABLED=1
GCS_BUCKET=skybridge-artifacts
GCS_PREFIX=jobs
GCS_LOCATION=us-central1
GCS_CREATE_BUCKET=1
BACKEND_CREDENTIAL_TTL=900
BACKEND_RECONCILE=true
BACKEND_WAIT_FOR_PROCESSING=true
BACKEND_PROCESSING_INTERVAL=20
BACKEND_PROCESSING_TIMEOUT=3600
BACKEND_OBJECT_STORE_DELETE_ON_CLEAR=false

# Firebase Auth (prod)
AUTH_ISSUER_URL=https://securetoken.google.com/<project_id>
AUTH_JWKS_URL=https://www.googleapis.com/robot/v1/metadata/x509/securetoken@system.gserviceaccount.com
AUTH_AUDIENCE=<project_id>
GCP_PROJECT_ID=<project_id>
GOOGLE_CLOUD_PROJECT=<project_id>

# Frontend display (optional, keeps UI copy in sync with backend retention)
VITE_RETENTION_DAYS=7

# Frontend (Firebase)
VITE_API_BASE_URL=https://<project-id>.web.app/api
VITE_AUTH_MODE=firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<project_id>
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_USE_EMULATOR=0
VITE_FIREBASE_AUTH_EMULATOR_HOST=https://skybridge.localhost
VITE_FIREBASE_ENABLE_GOOGLE=0
VITE_FIREBASE_ENABLE_APPLE=0
VITE_FIREBASE_ENABLE_FACEBOOK=0
VITE_FIREBASE_ENABLE_MICROSOFT=0
VITE_FIREBASE_ENABLE_GUEST=0
VITE_FIRESTORE_LISTEN=0
VITE_FIRESTORE_JOBS_COLLECTION=skybridge-jobs
VITE_DEV_PREFILL_CREDENTIALS=0
VITE_CLOUD_AHOY_EMAIL=
VITE_CLOUD_AHOY_PASSWORD=
VITE_FLYSTO_EMAIL=
VITE_FLYSTO_PASSWORD=
