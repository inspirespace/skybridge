CLOUD_AHOY_BASE_URL=https://www.cloudahoy.com/api
CLOUD_AHOY_WEB_BASE_URL=https://www.cloudahoy.com
DEV_USE_MOCKS=1
CLOUD_AHOY_EMAIL=
CLOUD_AHOY_PASSWORD=
CLOUD_AHOY_FLIGHTS_URL=
CLOUD_AHOY_EXPORT_URL_TEMPLATE=
CLOUD_AHOY_EXPORT_FORMAT=g3x
CLOUD_AHOY_EXPORT_FORMATS=g3x,gpx
FLYSTO_BASE_URL=https://www.flysto.net
FLYSTO_WEB_BASE_URL=https://www.flysto.net
FLYSTO_EMAIL=
FLYSTO_PASSWORD=
FLYSTO_UPLOAD_URL=
FLYSTO_SESSION_COOKIE=
FLYSTO_LOG_UPLOAD_URL=
FLYSTO_INCLUDE_METADATA=false
MODE=auto
BROWSER_HEADLESS=true
DRY_RUN=false
MAX_FLIGHTS=

# Backend (Firebase / GCP)
AUTH_EMULATOR_TRUST_TOKENS=false
APP_CHECK_ENFORCE=false
# Optional explicit project number for App Check verification.
# FIREBASE_PROJECT_NUMBER=
BACKEND_RETENTION_DAYS=7
# 32-byte urlsafe base64 key, e.g. generated via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKEND_ENCRYPTION_KEY=
CORS_ALLOW_ORIGINS=https://skybridge.localhost,https://emulator.skybridge.localhost
FIRESTORE_JOBS_COLLECTION=skybridge-jobs
FIRESTORE_CREDENTIALS_COLLECTION=skybridge-credentials
# Optional override; defaults to the Firebase default bucket for the active project.
# GCS_BUCKET=my-project.firebasestorage.app
GCS_PREFIX=jobs
BACKEND_CREDENTIAL_TTL=900
BACKEND_WAIT_FOR_PROCESSING=true
BACKEND_PROCESSING_INTERVAL=20
BACKEND_PROCESSING_TIMEOUT=3600
BACKEND_OBJECT_STORE_DELETE_ON_CLEAR=false

# Require passwordless email-link sign-in provider config in deploy preflight.
# FIREBASE_REQUIRE_EMAIL_LINK_SIGNIN=1
# Friendly app name hint shown in deploy preflight setup overview for Firebase Auth emails.
# FIREBASE_AUTH_EMAIL_APP_NAME=Skybridge
# Extra domains to allowlist for Firebase Auth email-link continue URLs (comma-separated hostnames).
# FIREBASE_AUTHORIZED_DOMAINS=skybridge.inspirespace.app,skybridge.inspirespace.co
# Enforce authorized-domain preflight as hard-fail (default: 1).
# FIREBASE_REQUIRE_AUTHORIZED_DOMAINS=1

# Frontend (Firebase)
# Optional override; defaults to same-origin /api (recommended for Firebase Hosting rewrites).
VITE_API_BASE_URL=/api
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APP_CHECK_ENABLED=0
VITE_FIREBASE_APP_CHECK_SITE_KEY=
# Optional debug token for local/dev App Check testing.
# VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
VITE_FIREBASE_USE_EMULATOR=0
VITE_FIREBASE_AUTH_EMULATOR_HOST=https://skybridge.localhost
VITE_FIREBASE_ENABLE_GOOGLE=0
VITE_FIREBASE_ENABLE_APPLE=0
VITE_FIREBASE_ENABLE_FACEBOOK=0
VITE_FIREBASE_ENABLE_MICROSOFT=0
VITE_FIREBASE_ENABLE_GUEST=0
VITE_FIRESTORE_LISTEN=0
# Optional override; defaults from FIRESTORE_JOBS_COLLECTION.
# VITE_FIRESTORE_JOBS_COLLECTION=skybridge-jobs
VITE_DEV_PREFILL_CREDENTIALS=0
# Optional display override; defaults from BACKEND_RETENTION_DAYS.
# VITE_RETENTION_DAYS=7
# Optional prefill overrides; defaults from CLOUD_AHOY_*/FLYSTO_*.
# VITE_CLOUD_AHOY_EMAIL=
# VITE_CLOUD_AHOY_PASSWORD=
# VITE_FLYSTO_EMAIL=
# VITE_FLYSTO_PASSWORD=
